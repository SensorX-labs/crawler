{
  "name": "SensorX.Miner",
  "version": "1.0.0",
  "description": "Data Miner, Importer and AI Training Simulator for SensorX",
  "main": "miner.js",
  "type": "module",
  "scripts": {
    "import:all":     "node miner.js import --all",
    "import:account": "node miner.js import --account",
    "import:product": "node miner.js import --product",
    "import:price":   "node miner.js import --price",
